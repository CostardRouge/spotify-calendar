# =============================================================================
# Spotify Library Calendar — environment configuration
# Copy this file to ".env" (make init does it for you) and fill in the values.
# =============================================================================

# --- Spotify app credentials -------------------------------------------------
# Create a free app at https://developer.spotify.com/dashboard
# and copy its Client ID / Client Secret here.
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# --- OAuth redirect URI ------------------------------------------------------
# Must EXACTLY match a Redirect URI registered in your Spotify app settings.
#   Local dev:  http://127.0.0.1:3000/api/auth/callback
#   Home Lab:   http://<optiplex-ip-or-host>:3000/api/auth/callback
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

# --- Host port ---------------------------------------------------------------
# Port published on the host (used by the Home Lab compose file). The app
# always listens on 3000 inside the container.
APP_PORT=3000

# --- Public site URL (for share links / PWA) ---------------------------------
# Origin where the app is publicly reachable. Used to build absolute Open Graph
# and Twitter card image URLs so a rich preview shows when you share the link.
# Leave unset for local dev (falls back to http://127.0.0.1:3000).
#   e.g. https://calendar.example.com   or   http://<optiplex-ip-or-host>:3000
# NEXT_PUBLIC_SITE_URL=https://calendar.example.com

# --- Caching -----------------------------------------------------------------
# The server caches your fetched library so reloads are instant and Spotify is
# only re-hit when the cache is stale (or you click Refresh).
# How long cached data stays fresh, in seconds (default 3600 = 1 hour).
CACHE_TTL_SECONDS=3600
# Where to persist the cache. Defaults to the OS temp dir. In the Home Lab
# compose this is set to /app/.cache and backed by a named volume so the cache
# survives container restarts.
# CACHE_DIR=/app/.cache
